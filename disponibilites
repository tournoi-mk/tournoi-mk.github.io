<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Disponibilités — Mario Kart Tournoi</title>
  <link href="https://fonts.googleapis.com/css2?family=Russo+One&family=Exo+2:wght@400;600;700;900&display=swap" rel="stylesheet">
  <style>
    :root{--red:#E8001D;--blue:#0052A5;--yellow:#FFD700;--dark:#07071a;}
    *{margin:0;padding:0;box-sizing:border-box;}
    body{background:var(--dark);font-family:'Exo 2',sans-serif;color:#fff;min-height:100vh;}
    .bg{position:fixed;inset:0;z-index:0;
      background:radial-gradient(ellipse 60% 40% at 20% 80%,rgba(0,82,165,0.15),transparent 60%),
        linear-gradient(180deg,#060610 0%,#0A0A1E 100%);}
    .top-bar{position:sticky;top:0;z-index:100;display:flex;align-items:center;padding:0 28px;height:64px;
      background:rgba(7,7,26,0.92);backdrop-filter:blur(12px);border-bottom:1px solid rgba(0,82,165,0.4);}
    .brand{font-family:'Russo One',sans-serif;font-size:0.9rem;letter-spacing:0.1em;color:var(--yellow);
      text-decoration:none;text-shadow:0 0 12px rgba(255,215,0,0.6);}
    .brand span{color:rgba(255,255,255,0.5);}
    .top-title{flex:1;text-align:center;font-family:'Russo One',sans-serif;font-size:1.3rem;letter-spacing:0.15em;}
    .back-btn{font-size:0.8rem;color:rgba(255,255,255,0.4);text-decoration:none;letter-spacing:0.1em;transition:color 0.2s;}
    .back-btn:hover{color:var(--blue);}
    .page{position:relative;z-index:1;max-width:800px;margin:0 auto;padding:48px 20px 80px;}
    h1{font-family:'Russo One',sans-serif;font-size:2rem;text-align:center;color:#6eb4ff;
      text-shadow:0 0 20px rgba(0,82,165,0.6);margin-bottom:12px;}
    .subtitle{text-align:center;color:rgba(255,255,255,0.4);letter-spacing:0.15em;font-size:0.85rem;
      text-transform:uppercase;margin-bottom:48px;}

    .form-card{background:rgba(255,255,255,0.04);border:1px solid rgba(0,82,165,0.3);border-radius:12px;padding:32px;}
    .form-group{margin-bottom:24px;}
    label{display:block;font-family:'Russo One',sans-serif;font-size:0.8rem;letter-spacing:0.12em;
      color:#6eb4ff;margin-bottom:8px;text-transform:uppercase;}
    input[type=text], input[type=email], select{
      width:100%;padding:12px 16px;background:rgba(255,255,255,0.06);
      border:1px solid rgba(255,255,255,0.12);border-radius:8px;
      color:#fff;font-family:'Exo 2',sans-serif;font-size:0.95rem;
      outline:none;transition:border-color 0.2s;}
    input[type=text]:focus, input[type=email]:focus, select:focus{border-color:var(--blue);}
    select option{background:#0A0A1E;}

    .days-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(120px,1fr));gap:10px;}
    .day-btn{
      padding:10px 8px;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);
      border-radius:8px;color:rgba(255,255,255,0.6);font-family:'Exo 2',sans-serif;font-size:0.82rem;
      cursor:pointer;text-align:center;transition:all 0.15s;user-select:none;}
    .day-btn:hover{background:rgba(0,82,165,0.2);border-color:var(--blue);}
    .day-btn.selected{background:rgba(0,82,165,0.35);border-color:var(--blue);color:#fff;
      box-shadow:0 0 12px rgba(0,82,165,0.4);}

    .submit-btn{
      width:100%;padding:16px;background:linear-gradient(135deg,#001530,#0052A5);
      border:1px solid var(--blue);border-radius:10px;color:#fff;
      font-family:'Russo One',sans-serif;font-size:1rem;letter-spacing:0.12em;
      cursor:pointer;transition:all 0.2s;margin-top:8px;}
    .submit-btn:hover{box-shadow:0 0 24px rgba(0,82,165,0.6);transform:translateY(-2px);}

    .success{display:none;text-align:center;padding:32px;
      background:rgba(0,82,165,0.15);border:1px solid rgba(0,82,165,0.4);border-radius:12px;}
    .success-icon{font-size:3rem;margin-bottom:12px;}
    .success h2{font-family:'Russo One',sans-serif;color:#6eb4ff;margin-bottom:8px;}
    .success p{color:rgba(255,255,255,0.5);font-size:0.9rem;}
  </style>
</head>
<body>
<div class="bg"></div>
<div class="top-bar">
  <a href="index.html" class="brand">🏆 <span>TOURNOI INTERNE</span> MARIO KART</a>
  <div class="top-title">Mes disponibilités</div>
  <a href="index.html" class="back-btn">← Accueil</a>
</div>
<div class="page">
  <h1>📅 MES DISPONIBILITÉS</h1>
  <p class="subtitle">Indiquez vos créneaux pour jouer les matchs</p>

  <div class="form-card" id="formCard">
    <div class="form-group">
      <label>Votre nom</label>
      <input type="text" id="playerName" placeholder="Prénom Nom">
    </div>
    <div class="form-group">
      <label>Votre tableau</label>
      <select id="tableau">
        <option value="">— Sélectionner —</option>
        <option value="1">Tableau 1 (Places 1-16)</option>
        <option value="2">Tableau 2 (Places 17-32)</option>
        <option value="3">Tableau 3 (Places 33-48)</option>
      </select>
    </div>
    <div class="form-group">
      <label>Jours disponibles</label>
      <div class="days-grid" id="daysGrid"></div>
    </div>
    <div class="form-group">
      <label>Créneaux horaires préférés</label>
      <div class="days-grid" id="timesGrid"></div>
    </div>
    <div class="form-group">
      <label>Commentaire (optionnel)</label>
      <input type="text" id="comment" placeholder="Ex: pas disponible après 19h...">
    </div>
    <button class="submit-btn" onclick="submitForm()">✅ ENREGISTRER MES DISPONIBILITÉS</button>
  </div>

  <div class="success" id="successMsg">
    <div class="success-icon">🏁</div>
    <h2>DISPONIBILITÉS ENREGISTRÉES !</h2>
    <p>Vos créneaux ont bien été pris en compte.<br>L'organisateur vous contactera pour fixer le match.</p>
  </div>
</div>

<script>
  const days = ['Lundi','Mardi','Mercredi','Jeudi','Vendredi','Samedi','Dimanche'];
  const times = ['Matin (8h-12h)','Midi (12h-14h)','Après-midi (14h-18h)','Soir (18h-21h)','Nuit (21h+)'];

  function buildButtons(containerId, items) {
    const grid = document.getElementById(containerId);
    items.forEach(item => {
      const btn = document.createElement('div');
      btn.className = 'day-btn';
      btn.textContent = item;
      btn.onclick = () => btn.classList.toggle('selected');
      grid.appendChild(btn);
    });
  }
  buildButtons('daysGrid', days);
  buildButtons('timesGrid', times);

  function submitForm() {
    const name = document.getElementById('playerName').value.trim();
    if (!name) { alert('Veuillez entrer votre nom.'); return; }
    document.getElementById('formCard').style.display = 'none';
    document.getElementById('successMsg').style.display = 'block';
  }
</script>
</body>
</html>
